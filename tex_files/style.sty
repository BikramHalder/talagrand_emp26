\definecolor{cerulean}{rgb}{0.0, 0.48, 0.65}

%% ── Theorem styles ────────────────────────────────────────────────
\declaretheoremstyle[name=Theorem, headfont={\sffamily\color{darkblue}}, bodyfont={\itshape}]{thmsty}
\declaretheorem[style=thmsty,numberwithin=section]{theorem}

\declaretheoremstyle[name=Proposition,]{prosty}
\declaretheorem[style=prosty,numberlike=theorem]{proposition}

\declaretheoremstyle[name=Definition, headfont={\sffamily\color{cerulean}}]{defsty}
\declaretheorem[style=defsty,numberlike=theorem]{definition}

\declaretheoremstyle[name=Lemma, bodyfont={\itshape}, headfont={\sffamily\color{darkblue}}]{prcpsty}
\declaretheorem[style=prcpsty,numberlike=theorem]{lemma}

\declaretheoremstyle[name=Remark, headfont={\sffamily\color{brightmaroon}}]{rmksty}
\declaretheorem[style=rmksty,numberlike=theorem]{remark}

\declaretheoremstyle[name=Example, headfont={\sffamily\color{bluegray}}]{egsty}
\declaretheorem[style=egsty,numberlike=theorem]{example}