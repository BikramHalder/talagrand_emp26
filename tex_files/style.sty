%% ── Macros ──────────────────────────────────────────────────────────────
\newcommand{\Q}{\ensuremath{\mathbb{Q}}} % Rational numbers
\newcommand{\N}{\ensuremath{\mathbb{N}}} % Natural numbers
\newcommand{\Z}{\ensuremath{\mathbb{Z}}} % Integers
\newcommand{\R}{\ensuremath{\mathbb{R}}} % Real numbers
\newcommand{\C}{\ensuremath{\mathbb{C}}} % Complex numbers
\renewcommand{\Pr}{\ensuremath{\mathbb{P}}} % renewed Probability symbol to the standard one
\newcommand{\E}{\ensuremath{\mathbb{E}}} % Expectation
\newcommand{\Var}{\ensuremath{\mathrm{Var}}} % Variance
\newcommand{\Cov}{\ensuremath{\mathrm{Cov}}} % Covariance
\newcommand{\indep}{\ensuremath{\perp\!\!\!\perp}} % Independence symbol
\newcommand{\iid}{\ensuremath{\overset{\text{iid}}{\sim}}} % i.i.d. symbol

